<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Склад стройматериалов</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-light border-bottom mb-3">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">Склад</a>
                <div class="navbar-nav">
                    <a class="nav-link" asp-controller="Products" asp-action="Index">Товары</a>
                    <a class="nav-link" asp-controller="Categories" asp-action="Index">Категории</a>
                    <a class="nav-link" asp-controller="StockMovements" asp-action="Index">Движение</a>
                    <a class="nav-link" asp-controller="Products" asp-action="Balances">Остатки</a>
                    <a class="nav-link" asp-controller="Products" asp-action="ReorderList">Ниже минимума</a>
                </div>
            </div>
        </nav>
    </header>
    <main class="container pb-3">
        @RenderBody()
    </main>
</body>
</html>
