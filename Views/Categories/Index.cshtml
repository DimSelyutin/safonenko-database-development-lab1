@model IEnumerable<Category>
@{
    ViewData["Title"] = "Категории";
}

<h2>Категории</h2>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Название</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">Подробнее</a>
            </td>
        </tr>
    }
    </tbody>
</table>
